{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 480,
  "padding": {"left": 0, "top": 0, "bottom": 0, "right": 8},
  "background": "white",
  "view": {"stroke": null},
  "config": {"view": {"stroke": null}},
  "projection": {"type": "mercator", "center": [134, -28], "scale": 580},

  "params": [
    {
      "name": "selectedMonth",
      "value": 1,
      "bind": {
        "input": "range",
        "min": 1,
        "max": 12,
        "step": 1,
        "name": "Month: "
      }
    }
  ],

  "data": {
    "url": "data/weather_cities.csv",
    "format": {
      "type": "csv",
      "parse": {
        "Date": "date",
        "MaxTemp": "number",
        "Rainfall": "number"
      }
    }
  },
  "transform": [
    {"filter": "datum.MaxTemp != null"},
    {"filter": "month(datum.Date) == selectedMonth - 1"},
    {
      "aggregate": [
        {"op": "mean", "field": "MaxTemp",  "as": "avgMaxTemp"},
        {"op": "mean", "field": "Rainfall", "as": "avgRainfall"}
      ],
      "groupby": ["Location"]
    },
    {
      "joinaggregate": [
        {"op": "mean", "field": "avgMaxTemp",  "as": "globalMaxTemp"},
        {"op": "mean", "field": "avgRainfall", "as": "globalRainfall"}
      ]
    },
    {"calculate": "isValid(datum.avgMaxTemp)   ? datum.avgMaxTemp   : datum.globalMaxTemp",   "as": "avgMaxTemp"},
    {"calculate": "isValid(datum.avgRainfall)  ? datum.avgRainfall  : datum.globalRainfall",  "as": "avgRainfall"},
    {
      "lookup": "Location",
      "from": {
        "data": {
          "values": [
            {"city": "Perth",     "lat": -31.95, "lon": 115.86},
            {"city": "Darwin",    "lat": -12.46, "lon": 130.84},
            {"city": "Brisbane",  "lat": -27.47, "lon": 153.02},
            {"city": "Sydney",    "lat": -33.86, "lon": 151.21},
            {"city": "Melbourne", "lat": -37.81, "lon": 144.96},
            {"city": "Adelaide",  "lat": -34.93, "lon": 138.60},
            {"city": "Hobart",    "lat": -42.88, "lon": 147.33}
          ]
        },
        "key": "city",
        "fields": ["lat", "lon"]
      }
    }
  ],

  "resolve": {
    "scale": {"color": "independent", "size": "independent"},
    "legend": {"color": "independent", "size": "independent"}
  },

  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.min.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "mark": {"type": "geoshape", "fill": null, "stroke": "#bbb", "strokeWidth": 0.8}
    },
    {
      "data": {
        "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "transform": [{"filter": "datum.id == 36"}],
      "mark": {"type": "geoshape", "fill": "#e8e8e8", "stroke": "white", "strokeWidth": 0.5}
    },
    {
      "mark": {"type": "circle", "stroke": "#555", "strokeWidth": 1, "opacity": 0.85},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "size": {
          "field": "avgRainfall",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [2.5, 4.0],
            "range": [200, 650, 1400]
          },
          "legend": {
            "title": "Average Rainfall (mm/day)",
            "orient": "none",
            "legendX": 8,
            "legendY": 358,
            "direction": "horizontal",
            "titleFontSize": 10,
            "labelFontSize": 9,
            "values": [1.8, 3.0, 5.0],
            "format": ".1f"
          }
        },
        "color": {
          "field": "avgMaxTemp",
          "type": "quantitative",
          "scale": {"type": "threshold", "domain": [20,24,28,32], "range": ["#fee5d9","#fcae91","#fb6a4a","#de2d26","#a50f15"]},
          "legend": {
            "title": "Average Max Temp (°C)",
            "orient": "none",
            "legendX": 8,
            "legendY": 415,
            "direction": "horizontal",
            "titleFontSize": 10,
            "labelFontSize": 9
          }
        },
        "tooltip": [
          {"field": "Location",    "title": "City"},
          {"field": "avgMaxTemp",  "title": "Average Max Temp (°C)", "format": ".1f"},
          {"field": "avgRainfall", "title": "Average Rainfall (mm/day)", "format": ".2f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "dy": -18, "fontSize": 11, "fontWeight": "bold", "fill": "#000", "align": "center", "baseline": "bottom"},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "text": {"field": "Location"}
      }
    },

    {"transform":[{"filter":"selectedMonth==1"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["January: Peak summer across all capitals.", "Darwin's monsoon at its highest monthly peak;", "Adelaide often rivals Darwin for heat."]}}},
    {"transform":[{"filter":"selectedMonth==2"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["February: Darwin's wettest month,", "monsoon at full force.", "Southern capitals still hot before autumn cooling."]}}},
    {"transform":[{"filter":"selectedMonth==3"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["March: Darwin's wet season winds down.", "Southern capitals begin cooling into autumn;", "temperature gaps start to narrow."]}}},
    {"transform":[{"filter":"selectedMonth==4"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["April: Darwin's wet season ends sharply;", "rainfall collapses to near zero.", "Southern capitals cool steadily."]}}},
    {"transform":[{"filter":"selectedMonth==5"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["May: Darwin dry season establishes,", "warm and bone dry.", "Hobart already cold; southern cooling continues."]}}},
    {"transform":[{"filter":"selectedMonth==6"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["June: Darwin mild and dry,", "peak tourist season.", "Southern capitals deep in mid-winter cold."]}}},
    {"transform":[{"filter":"selectedMonth==7"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["July: Coldest month for all southern capitals.", "Darwin warm and dry;", "widest north-south temperature gap of the year."]}}},
    {"transform":[{"filter":"selectedMonth==8"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["August: Winter holds in the south;", "Darwin still dry.", "Temperature spread near its annual maximum."]}}},
    {"transform":[{"filter":"selectedMonth==9"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["September: Spring warming arrives in the south.", "Darwin heats toward the pre-monsoon build;", "rainfall still very low."]}}},
    {"transform":[{"filter":"selectedMonth==10"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["October: Rapid spring warming in southern cities.", "Darwin's heat peaks before monsoon breaks;", "humidity and bubble size both surge."]}}},
    {"transform":[{"filter":"selectedMonth==11"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["November: Darwin hottest and most humid", "before the monsoon.", "Southern cities warm into early summer."]}}},
    {"transform":[{"filter":"selectedMonth==12"}],"data":{"values":[{}]},"mark":{"type":"text","align":"left","fontSize":9,"fontStyle":"italic","fill":"#222","lineHeight":13},"encoding":{"x":{"value":8},"y":{"value":42},"text":{"value":["December: Darwin's first monsoon rains arrive;", "bubble size surges.", "Southern cities hit summer heat peak."]}}}
  ]
}
