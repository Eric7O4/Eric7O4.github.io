{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 431,
  "view": {"stroke": null},

  "params": [
    {
      "name": "selectedCity",
      "value": "Darwin",
      "bind": {
        "input": "select",
        "options": ["Darwin","Brisbane","Perth","Sydney","Adelaide","Melbourne","Hobart"],
        "name": "City: "
      }
    },
    {
      "name": "selectedYear",
      "value": -1,
      "bind": {
        "input": "select",
        "options": [-1,2008,2009,2010,2011,2012,2013,2014,2015,2016,2017],
        "labels": ["All Years","2008","2009","2010","2011","2012","2013","2014","2015","2016","2017"],
        "name": "Year: "
      }
    }
  ],

  "resolve": {
    "scale": {"color": "independent", "radius": "independent"},
    "legend": {"color": "independent"}
  },

  "layer": [
    {
      "description": "Grid rings",
      "data": {
        "values": [
          {"r": 55},
          {"r": 99},
          {"r": 144}
        ]
      },
      "mark": {
        "type": "arc",
        "fillOpacity": 0,
        "stroke": "#e0e0e0",
        "strokeWidth": 0.8
      },
      "encoding": {
        "theta":  {"value": 0},
        "theta2": {"value": 6.2832},
        "radius":  {"field": "r", "type": "quantitative", "scale": null},
        "radius2": {"value": 0}
      }
    },
    {
      "description": "Ring percentage labels",
      "data": {
        "values": [
          {"r": 55,  "label": "10%"},
          {"r": 99,  "label": "20%"},
          {"r": 144, "label": "30%"}
        ]
      },
      "mark": {"type": "text", "fontSize": 8, "fill": "#bbb", "align": "left", "dx": 3, "dy": -3},
      "encoding": {
        "theta":  {"value": 0.5},
        "radius": {"field": "r", "type": "quantitative", "scale": null},
        "text":   {"field": "label"}
      }
    },
    {
      "description": "Wind direction bars",
      "data": {
        "url": "data/weather_cities.csv",
        "format": {"type": "csv", "parse": {"Date": "date"}}
      },
      "transform": [
        {
          "filter": "isValid(datum.WindDir3pm) && datum.WindDir3pm != '' && datum.WindDir3pm != 'Calm' && datum.Location == selectedCity && (selectedYear == -1 || year(datum.Date) == selectedYear)"
        },
        {
          "aggregate": [{"op": "count", "field": "WindDir3pm", "as": "count"}],
          "groupby": ["WindDir3pm"]
        },
        {
          "joinaggregate": [{"op": "sum", "field": "count", "as": "totalCount"}]
        },
        {"calculate": "datum.count / datum.totalCount * 100", "as": "pct"},
        {
          "calculate": "{'N':0,'NNE':22.5,'NE':45,'ENE':67.5,'E':90,'ESE':112.5,'SE':135,'SSE':157.5,'S':180,'SSW':202.5,'SW':225,'WSW':247.5,'W':270,'WNW':292.5,'NW':315,'NNW':337.5}[datum.WindDir3pm]",
          "as": "dirDeg"
        },
        {"filter": "isValid(datum.dirDeg)"},
        {"calculate": "datum.dirDeg * PI / 180", "as": "dirRad"},
        {"calculate": "datum.dirRad - PI / 16", "as": "startAngle"},
        {"calculate": "datum.dirRad + PI / 16", "as": "endAngle"}
      ],
      "mark": {
        "type": "arc",
        "stroke": "white",
        "strokeWidth": 0.5,
        "fillOpacity": 0.85
      },
      "encoding": {
        "theta":  {"field": "startAngle", "type": "quantitative", "scale": null, "stack": null},
        "theta2": {"field": "endAngle",   "type": "quantitative"},
        "radius": {
          "field": "pct",
          "type": "quantitative",
          "scale": {"type": "linear", "domain": [0, 30], "range": [10, 144]},
          "legend": null
        },
        "radius2": {"value": 10},
        "color": {
          "condition": [
            {"test": "selectedCity == 'Darwin'",    "value": "#c0392b"},
            {"test": "selectedCity == 'Brisbane'",  "value": "#e67e22"},
            {"test": "selectedCity == 'Perth'",     "value": "#17a589"},
            {"test": "selectedCity == 'Sydney'",    "value": "#e84393"},
            {"test": "selectedCity == 'Adelaide'",  "value": "#8e44ad"},
            {"test": "selectedCity == 'Melbourne'", "value": "#2980b9"}
          ],
          "value": "#34495e"
        },
        "tooltip": [
          {"field": "WindDir3pm", "title": "Direction"},
          {"field": "pct",        "title": "Frequency (%)", "format": ".1f"}
        ]
      }
    },
    {
      "description": "Percentage value labels on bars",
      "data": {
        "url": "data/weather_cities.csv",
        "format": {"type": "csv", "parse": {"Date": "date"}}
      },
      "transform": [
        {
          "filter": "isValid(datum.WindDir3pm) && datum.WindDir3pm != '' && datum.WindDir3pm != 'Calm' && datum.Location == selectedCity && (selectedYear == -1 || year(datum.Date) == selectedYear)"
        },
        {
          "aggregate": [{"op": "count", "field": "WindDir3pm", "as": "count"}],
          "groupby": ["WindDir3pm"]
        },
        {
          "joinaggregate": [{"op": "sum", "field": "count", "as": "totalCount"}]
        },
        {"calculate": "datum.count / datum.totalCount * 100", "as": "pct"},
        {"filter": "datum.pct >= 4"},
        {
          "calculate": "{'N':0,'NNE':22.5,'NE':45,'ENE':67.5,'E':90,'ESE':112.5,'SE':135,'SSE':157.5,'S':180,'SSW':202.5,'SW':225,'WSW':247.5,'W':270,'WNW':292.5,'NW':315,'NNW':337.5}[datum.WindDir3pm]",
          "as": "dirDeg"
        },
        {"filter": "isValid(datum.dirDeg)"},
        {"calculate": "datum.dirDeg * PI / 180", "as": "dirRad"}
      ],
      "mark": {"type": "text", "fontSize": 8, "fontWeight": "600", "fill": "#333", "align": "center", "baseline": "middle"},
      "encoding": {
        "theta": {"field": "dirRad", "type": "quantitative", "scale": null},
        "radius": {
          "field": "pct",
          "type": "quantitative",
          "scale": {"type": "linear", "domain": [0, 30], "range": [26, 160]},
          "legend": null
        },
        "text": {"field": "pct", "type": "quantitative", "format": ".1f"}
      }
    },
    {
      "description": "Cardinal direction labels",
      "data": {
        "values": [
          {"label": "N",  "angle": 0},
          {"label": "NE", "angle": 0.7854},
          {"label": "E",  "angle": 1.5708},
          {"label": "SE", "angle": 2.3562},
          {"label": "S",  "angle": 3.1416},
          {"label": "SW", "angle": 3.9270},
          {"label": "W",  "angle": 4.7124},
          {"label": "NW", "angle": 5.4978}
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "600",
        "fill": "#555",
        "align": "center",
        "baseline": "middle"
      },
      "encoding": {
        "theta":  {"field": "angle", "type": "quantitative", "scale": null},
        "radius": {"value": 170},
        "text":   {"field": "label"}
      }
    }
  ]
}
