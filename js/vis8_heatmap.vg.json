{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": "container",
  "height": "container",

  "data": { "url": "data/weather_cities.csv" },

  "resolve": {"legend": {"color": "independent"}},

  "layer": [
    {
      "params": [
        {
          "name": "cityHighlight",
          "select": { "type": "point", "fields": ["Location"], "on": "click" },
          "bind": "legend"
        }
      ],
      "mark": "area",
      "encoding": {
        "x": {
          "field": "Date",
          "type": "temporal",
          "timeUnit": "yearmonth",
          "title": "Date",
          "axis": { "labelAngle": -30 }
        },
        "y": {
          "aggregate": "sum",
          "field": "Rainfall",
          "type": "quantitative",
          "stack": null,
          "axis": {
            "title": ["Rainfall", "(mm)"],
            "titleAngle": 0,
            "titleAnchor": "end",
            "titleAlign": "right"
          }
        },
        "color": {
          "field": "Location",
          "type": "nominal",
          "title": "Capital City",
          "scale": {
            "domain": ["Darwin","Brisbane","Perth","Sydney","Adelaide","Melbourne","Hobart"],
            "range": ["#c0392b","#e67e22","#17a589","#e84393","#8e44ad","#2980b9","#34495e"]
          }
        },
        "opacity": {
          "condition": { "param": "cityHighlight", "value": 1 },
          "value": 0.15
        },
        "tooltip": [
          { "field": "Location", "type": "nominal", "title": "Capital City" },
          { "field": "Date", "type": "temporal", "timeUnit": "yearmonth", "title": "Month" },
          { "aggregate": "sum", "field": "Rainfall", "type": "quantitative", "title": "Total Rainfall (mm)", "format": ".1f" }
        ]
      }
    },
    {
      "data": {"values": [
        {"d": "2009-02-01", "textY": 900,  "label": ["Darwin:", "wet season peak"],  "col": "#c0392b"},
        {"d": "2010-12-01", "textY": 1150, "label": ["La Nina", "2010-11 surge"],    "col": "#e67e22"},
        {"d": "2013-07-01", "textY": 700,  "label": ["Darwin:", "dry season low"],   "col": "#555555"},
        {"d": "2015-06-01", "textY": 780,  "label": ["Perth:", "driest southern capital"], "col": "#17a589"}
      ]},
      "mark": {"type": "text", "align": "left", "fontSize": 9, "fontStyle": "italic", "clip": false, "dy": -4},
      "encoding": {
        "x": {"field": "d", "type": "temporal"},
        "y": {"field": "textY", "type": "quantitative"},
        "text": {"field": "label"},
        "color": {"field": "col", "type": "nominal", "scale": null, "legend": null}
      }
    },
    {
      "data": {"values": [
        {"d": "2009-02-01", "y1": 896,  "y2": 600,  "col": "#c0392b"},
        {"d": "2010-12-01", "y1": 1146, "y2": 1060, "col": "#e67e22"},
        {"d": "2013-07-01", "y1": 696,  "y2":  30,  "col": "#555555"},
        {"d": "2015-06-01", "y1": 776,  "y2":  55,  "col": "#17a589"}
      ]},
      "mark": {"type": "rule", "strokeWidth": 1, "strokeDash": [3, 2]},
      "encoding": {
        "x":  {"field": "d",   "type": "temporal"},
        "y":  {"field": "y1",  "type": "quantitative"},
        "y2": {"field": "y2"},
        "color": {"field": "col", "type": "nominal", "scale": null, "legend": null}
      }
    },
    {
      "data": {"values": [
        {"d": "2009-02-01", "y": 600,  "col": "#c0392b"},
        {"d": "2010-12-01", "y": 1060, "col": "#e67e22"},
        {"d": "2013-07-01", "y":  30,  "col": "#555555"},
        {"d": "2015-06-01", "y":  55,  "col": "#17a589"}
      ]},
      "mark": {"type": "text", "fontSize": 9},
      "encoding": {
        "x": {"field": "d", "type": "temporal"},
        "y": {"field": "y", "type": "quantitative"},
        "text": {"value": "▼"},
        "color": {"field": "col", "type": "nominal", "scale": null, "legend": null}
      }
    }
  ]
}
