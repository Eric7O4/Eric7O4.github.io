  "layer": [
    {
      "params": [
        {
          "name": "cityHighlight",
          "select": { "type": "point", "fields": ["city"], "on": "click" },
          "bind": "legend"
        }
      ],
      "mark": {
        "type": "line",
        "point": { "filled": true, "size": 80 }
      },
      "encoding": { 
        "x": {  
          "field": "metric",
          "type": "nominal",
          "sort": ["Max Temp","Rainfall","Wind Speed","Humidity","Rain Days"],
          "axis": { "labelAngle": 0, "labelFontSize": 12, "labelFontWeight": "bold" },
          "title": null
        },
        "y": {
          "field": "norm",
          "type": "quantitative",
          "scale": { "domain": [0, 1] },
          "axis": {
            "title": ["Normalised Score", "(0 = lowest, 1 = highest)"],
            "tickCount": 5,
            "grid": true,
            "titleAngle": 0,
            "titleAnchor": "end",
            "titleAlign": "right"
          }
        },
        "color": {
          "field": "city",
          "type": "nominal",
          "title": "Capital City",
          "scale": {
            "domain": ["Darwin","Brisbane","Perth","Sydney","Adelaide","Melbourne","Hobart"],
            "range": ["#c0392b","#e67e22","#17a589","#e84393","#8e44ad","#2980b9","#34495e"]
          }
        },
        "detail": { "field": "city", "type": "nominal" },
        "opacity": {
          "condition": { "param": "cityHighlight", "value": 1 },
          "value": 0.08
        },
        "tooltip": [
          { "field": "city",   "type": "nominal", "title": "Capital City" },
          { "field": "metric", "type": "nominal", "title": "Metric" },
          { "field": "raw",    "type": "nominal", "title": "Value" }
        ]
      }
    },
    {
      "data": {
        "values": [
          { "metric": "Max Temp",  "norm": 0.96, "note": "↑ Darwin leads" },
          { "metric": "Wind Speed","norm": 0.96, "note": "↑ Melbourne leads" },
          { "metric": "Humidity",  "norm": 0.96, "note": "↑ Sydney leads" }
        ]
      },
      "mark": { "type": "text", "align": "center", "fontSize": 8.5, "fontStyle": "italic", "color": "#555", "dy": -10 },
      "encoding": {
        "x": {
          "field": "metric",
          "type": "nominal",
          "sort": ["Max Temp","Rainfall","Wind Speed","Humidity","Rain Days"]
        },
        "y": { "field": "norm", "type": "quantitative" },
        "text": { "field": "note", "type": "nominal" }
      }
    }
  ]
}
