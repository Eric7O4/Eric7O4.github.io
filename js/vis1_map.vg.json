{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 540,
  "height": 360,

  "projection": {
    "type": "mercator",
    "center": [134, -28],
    "scale": 480
  },

  "layer": [
    {
      "data": {
        "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
        "format": { "type": "topojson", "feature": "countries" }
      },
      "transform": [ { "filter": "datum.id == 36" } ],
      "mark": { "type": "geoshape", "fill": "lightgray", "stroke": "white" }
    },

    {
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.min.geojson",
        "format": { "type": "json", "property": "features" }
      },
      "mark": { "type": "geoshape", "fill": null, "stroke": "#aaa", "strokeWidth": 0.7 }
    },

    {
      "data": {
        "values": [
          {"city": "Perth",     "lat": -31.95, "lon": 115.86, "avgMaxTemp": 25.0},
          {"city": "Adelaide",  "lat": -34.93, "lon": 138.60, "avgMaxTemp": 22.9},
          {"city": "Melbourne", "lat": -37.81, "lon": 144.96, "avgMaxTemp": 21.1},
          {"city": "Hobart",    "lat": -42.88, "lon": 147.33, "avgMaxTemp": 17.9},
          {"city": "Sydney",    "lat": -33.86, "lon": 151.21, "avgMaxTemp": 23.0},
          {"city": "Brisbane",  "lat": -27.47, "lon": 153.02, "avgMaxTemp": 26.4},
          {"city": "Darwin",    "lat": -12.46, "lon": 130.84, "avgMaxTemp": 32.5}
        ]
      },
      "mark": { "type": "circle", "opacity": 0.9, "size": 350 },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude":  { "field": "lat", "type": "quantitative" },
        "color": {
          "field": "avgMaxTemp",
          "type": "quantitative",
          "title": "Average Max Temp (°C)",
          "scale": {
            "type": "threshold",
            "domain": [20, 24, 28, 32],
            "scheme": "reds"
          },
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "values": [17, 20, 24, 28, 32, 34]
          }
        },
        "tooltip": [
          { "field": "city",       "type": "nominal",     "title": "Capital City" },
          { "field": "avgMaxTemp", "type": "quantitative","title": "Average Max Temp (°C)" }
        ]
      }
    }
  ]
}
